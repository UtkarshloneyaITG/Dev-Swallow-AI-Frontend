# Build output
# ───────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ───────────────────────────────────────────────
# Environment variables  ← IMPORTANT: never commit secrets
# ───────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# Keep the example/template so others know what vars are needed
!.env.example

# ───────────────────────────────────────────────
# Vite / TypeScript cache
# ───────────────────────────────────────────────
*.tsbuildinfo
.vite/
vite.config.ts.timestamp-*

# ───────────────────────────────────────────────
# Editor & OS
# ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# VS Code (keep workspace settings if desired, ignore personal ones)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains / IntelliJ
.idea/

# ───────────────────────────────────────────────
# Logs & debug
# ───────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ───────────────────────────────────────────────
# Test / coverage
